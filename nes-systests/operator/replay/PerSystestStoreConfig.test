# name: operator/replay/PerSystestStoreConfig.test
# description: Demonstrates per-systest store configuration via REPLAYABLE SET(...)
# groups: [Store, Read]

REPLAYABLE SET(
    '32MB' AS REPLAY.MEMORY_BUFFER_SIZE,
    'MemoryStore->FileStore'   AS REPLAY.STORE_ORDER
)

SEQUENTIAL_EXECUTION

CREATE LOGICAL SOURCE stream(id UINT64, value UINT64, ts UINT64);
CREATE PHYSICAL SOURCE FOR stream TYPE File;
ATTACH INLINE
1,1,1000
2,1,1001
3,1,1002
4,2,2000

CREATE SINK sinkStore(stream.id UINT64, stream.value UINT64, stream.ts UINT64) TYPE File;
CREATE SINK sinkRead(stream.id UINT64, stream.value UINT64, stream.ts UINT64) TYPE File;

# 1: store rows using the configured store
SELECT id, value, ts FROM stream INTO sinkStore;
----
1,1,1000
2,1,1001
3,1,1002
4,2,2000

# 2: read back with time travel — store uses the configured buffer size and ordering
SELECT id, value, ts FROM stream FOR EVENT_TIME AS OF TIMESTAMP '1001' INTO sinkRead;
----
2,1,1001
3,1,1002
4,2,2000
