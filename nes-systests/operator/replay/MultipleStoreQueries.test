# name: operator/replay/MultipleStoreQueries.test
# description: Tests that multiple store queries work
# groups: [Store, Read]

REPLAYABLE

SEQUENTIAL_EXECUTION

CREATE LOGICAL SOURCE stream(id UINT64, value UINT64, ts UINT64);
CREATE PHYSICAL SOURCE FOR stream TYPE File;
ATTACH INLINE
1,1,1000
2,1,1001
3,1,1002
4,2,2000

CREATE LOGICAL SOURCE stream2(id UINT64, value UINT64, ts UINT64);
CREATE PHYSICAL SOURCE FOR stream2 TYPE File;
ATTACH INLINE
1,1,1000
2,1,1001
3,1,1002
4,2,2000

CREATE SINK sinkStore(stream.id UINT64, stream.value UINT64, stream.ts UINT64) TYPE File;
CREATE SINK sinkRead(stream.id UINT64, stream.value UINT64, stream.ts UINT64) TYPE File;

CREATE SINK sinkStore2(stream2.id UINT64, stream2.value UINT64, stream2.ts UINT64) TYPE File;
CREATE SINK sinkRead2(stream2.id UINT64, stream2.value UINT64, stream2.ts UINT64) TYPE File;

# 1: store rows from stream into replay store
SELECT id, value, ts FROM stream INTO sinkStore;
----
1,1,1000
2,1,1001
3,1,1002
4,2,2000

SELECT id, value, ts FROM stream FOR EVENT_TIME AS OF TIMESTAMP '1000' INTO sinkRead;
----
1,1,1000
2,1,1001
3,1,1002
4,2,2000

# 2: store rows from stream2 into a separate replay store
SELECT id, value, ts FROM stream2 INTO sinkStore2;
----
1,1,1000
2,1,1001
3,1,1002
4,2,2000

SELECT id, value, ts FROM stream2 FOR EVENT_TIME AS OF TIMESTAMP '1000' INTO sinkRead2;
----
1,1,1000
2,1,1001
3,1,1002
4,2,2000
