# name: operator/store-read/StoreRead_TimeTravel.test
# description: Store stream to binary via REPLAYABLE and read back with time travel
# groups: [Store, Read]

REPLAYABLE

SEQUENTIAL_EXECUTION

CREATE LOGICAL SOURCE stream(id UINT64, value UINT64, ts UINT64);
CREATE PHYSICAL SOURCE FOR stream TYPE File;
ATTACH INLINE
1,1,1000
2,1,1001
3,1,1002
4,2,2000

CREATE SINK sinkStore(stream.id UINT64, stream.value UINT64, stream.ts UINT64) TYPE File;
CREATE SINK sinkRead(stream.id UINT64, stream.value UINT64, stream.ts UINT64) TYPE File;

# 1: store rows to binary file and also write to a sink for comparison
SELECT id, value, ts FROM stream INTO sinkStore;
----
1,1,1000
2,1,1001
3,1,1002
4,2,2000

SELECT id, value, ts FROM stream FOR EVENT_TIME AS OF TIMESTAMP '1002' INTO sinkRead;
----
3,1,1002
4,2,2000
